---
import BaseLayout from '../layouts/BaseLayout.astro';

const currentYear = new Date().getFullYear();
const experienceYears = currentYear - 2013;
---

<BaseLayout 
    title={`About Sakar Upadhyaya Khatiwada | Zendesk Solution Architect & Shopify Engineer`}
    description={`Sakar Upadhyaya Khatiwada is a Nepal-based Zendesk Solution Architect and Shopify Engineer with ${experienceYears}+ years of experience. He has engineered enterprise-grade CX platforms, custom Zendesk apps, and scalable e-commerce solutions for global clients including Stylo, ClickSend, and ApplyBoard.`}
>
    <main class="pt-24 pb-20 max-w-7xl mx-auto px-8 w-full overflow-hidden">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <div class="lg:col-span-7">
                    <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-4 block">{experienceYears}+ Years of Engineering Excellence</span>
                    <h1 class="font-headline text-6xl md:text-7xl font-extrabold tracking-tighter leading-tight mb-8">
                        <span class="text-primary italic">Building and Integrating</span> Systems for better outcomes.
                    </h1>
                    <p class="font-body text-xl text-on-surface-variant leading-relaxed max-w-2xl">
                        Based in <span class="text-primary font-semibold">Nepal</span>, I have built custom solutions for global clients like <span class="text-primary font-semibold">Stylo</span>, <span class="text-primary font-semibold">ClickSend</span>, and <span class="text-primary font-semibold">ApplyBoard</span>. I specialize in <span class="text-primary font-bold">Customer Experience (CX)</span>, <span class="text-primary font-bold">Management Systems</span>, and high-performance <span class="text-primary font-bold">Shopify engineering</span>.
                    </p>
                </div>
                <div class="lg:col-span-5 relative group">
                    <div class="absolute -inset-4 bg-primary-fixed rounded-xl opacity-20 group-hover:opacity-30 transition-opacity"></div>
                    <img alt="Sakar Upadhyaya Khatiwada" class="relative w-full aspect-square object-cover rounded-xl grayscale hover:grayscale-0 transition-all duration-500 shadow-xl" src="/images/site_image.png"/>
                </div>
            </div>
        </section>

        <!-- Professional Journey Timeline Section -->
        <section class="max-w-7xl mx-auto mb-32">
            <div class="flex flex-col lg:flex-row gap-16">
                <!-- Sidebar -->
                <div class="lg:w-1/3">
                    <div class="sticky top-32">
                        <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-4 block">Experience</span>
                        <h2 class="font-headline text-5xl font-extrabold leading-tight mb-6">Professional <br/>Journey</h2>
                        <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                            A track record of delivering robust, scalable solutions and leading engineering efforts across global organizations.
                        </p>
                        <!-- Decorative element -->
                        <div class="w-16 h-2 rounded-full bg-gradient-to-r from-primary to-tertiary"></div>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="lg:w-2/3 relative pt-4">
                    <!-- Timeline Line -->
                    <div class="absolute left-8 top-8 bottom-0 w-1 bg-gradient-to-b from-primary via-tertiary to-transparent timeline-line rounded-full hidden md:block origin-top"></div>
                    
                    <div class="space-y-12">
                        <!-- Freelance Role -->
                        <div class="relative pl-0 md:pl-24 group journey-item">
                            <!-- Timeline Node -->
                            <div class="absolute left-6 top-8 w-5 h-5 rounded-full bg-surface ring-[6px] ring-primary z-10 hidden md:block journey-node transition-all duration-300 group-hover:scale-125 group-hover:ring-tertiary shadow-[0_0_15px_rgba(var(--color-primary-rgb),0.5)]"></div>
                            
                            <!-- Card -->
                            <div class="bg-surface-container-low rounded-3xl p-8 md:p-10 border border-transparent hover:border-primary/20 transition-all duration-500 hover:shadow-2xl hover:shadow-primary/5 hover:-translate-y-1 relative overflow-hidden">
                                <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-bl-full -z-10 transition-transform group-hover:scale-110 duration-500"></div>
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
                                    <div>
                                        <h3 class="font-headline text-2xl font-bold text-on-surface">Consultant / Development</h3>
                                        <p class="font-label text-base text-primary font-bold mt-1">Freelance</p>
                                    </div>
                                    <span class="font-label text-on-surface-variant font-bold text-xs bg-surface-container-highest px-4 py-2 rounded-full uppercase tracking-wider self-start sm:self-auto border border-surface-container-highest">JUNE 2019 — PRESENT</span>
                                </div>
                                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                                    Delivering high-level architectural consulting for <span class="text-primary font-semibold">Zendesk</span> and <span class="text-primary font-semibold">Shopify</span>. Focused on building custom solutions, training teams on the technology to achieve better results, and designing the processes and systems that bridge management tools with exceptional customer experience.
                                </p>
                                <ul class="space-y-4 font-body text-on-surface-variant">
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Built Zendesk app for <span class="text-primary font-semibold">ClickSend Australia</span></span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Consulted and built custom scripts to improve the customer support flow for <span class="text-primary font-semibold">ApplyBoard Canada</span> and <span class="text-primary font-semibold">Barlife Denmark</span></span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Assisted <span class="text-primary font-semibold">Zendesk Admins</span> with development tasks and the implementation of Webhooks and Zendesk Integration Service (ZIS) to improve support agent workflows</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Helped a <span class="text-primary font-semibold">Shopify store based in Switzerland</span> improve their SEO performance by auditing their store and theme and recommending targeted integrations</span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Senior Role -->
                        <div class="relative pl-0 md:pl-24 group journey-item">
                            <div class="absolute left-6 top-8 w-5 h-5 rounded-full bg-surface ring-[6px] ring-tertiary/70 z-10 hidden md:block journey-node transition-all duration-300 group-hover:scale-125 group-hover:ring-tertiary"></div>
                            
                            <div class="bg-surface-container-low rounded-3xl p-8 md:p-10 border border-transparent hover:border-tertiary/20 transition-all duration-500 hover:shadow-2xl hover:shadow-tertiary/5 hover:-translate-y-1 relative overflow-hidden">
                                <div class="absolute top-0 right-0 w-32 h-32 bg-tertiary/5 rounded-bl-full -z-10 transition-transform group-hover:scale-110 duration-500"></div>
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
                                    <div>
                                        <h3 class="font-headline text-2xl font-bold text-on-surface">Zendesk / Frontend Engineer</h3>
                                        <p class="font-label text-base text-tertiary font-bold mt-1">Stylo (US)</p>
                                    </div>
                                    <span class="font-label text-on-surface-variant font-bold text-xs bg-surface-container-highest px-4 py-2 rounded-full uppercase tracking-wider self-start sm:self-auto border border-surface-container-highest">DEC 2022 — APRIL 2024</span>
                                </div>
                                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                                    Developed the front-end interface for <span class="text-primary font-semibold">Stylo's Zendesk AI integrations</span>, transforming complex designs into fully API-connected applications used by enterprise support teams globally.
                                </p>
                                <ul class="space-y-4 font-body text-on-surface-variant">
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-tertiary bg-tertiary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Engineered the <span class="text-primary font-semibold">Stylo Assist App</span> (ZAF Client + React), now a key AI solution in the Zendesk Marketplace.</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-tertiary bg-tertiary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Integrated REST APIs via the Zendesk App Framework (ZAF) to deliver a user-friendly AI companion for support agents.</span>
                                    </li>
                                     <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-tertiary bg-tertiary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Integrated Feature Flags and product metrics tooling to enable fact-based decision-making by the product management team.</span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Full Stack Role -->
                        <div class="relative pl-0 md:pl-24 group journey-item">
                            <div class="absolute left-6 top-8 w-5 h-5 rounded-full bg-surface ring-[6px] ring-secondary/50 z-10 hidden md:block journey-node transition-all duration-300 group-hover:scale-125 group-hover:ring-secondary"></div>
                            
                            <div class="bg-surface-container-low rounded-3xl p-8 md:p-10 border border-transparent hover:border-secondary/20 transition-all duration-500 hover:shadow-2xl hover:shadow-secondary/5 hover:-translate-y-1 relative overflow-hidden">
                                <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/5 rounded-bl-full -z-10 transition-transform group-hover:scale-110 duration-500"></div>
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
                                    <div>
                                        <h3 class="font-headline text-2xl font-bold text-on-surface">Full Stack Developer</h3>
                                        <p class="font-label text-base text-secondary font-bold mt-1">Proshore Nepal</p>
                                    </div>
                                    <span class="font-label text-on-surface-variant font-bold text-xs bg-surface-container-highest px-4 py-2 rounded-full uppercase tracking-wider self-start sm:self-auto border border-surface-container-highest">March 2014 — Nov 2022</span>
                                </div>
                                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                                    Developed and optimized high-traffic SaaS applications for European and Australian clients, and built internal systems that supported full-cycle organizational operations.
                                </p>
                                <ul class="space-y-4 font-body text-on-surface-variant">
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Maintained , Upgraded and Developed new feature for a <span class="text-primary font-semibold">Transport Management System</span> for <span class="text-primary font-semibold">Demeubeltaxi</span> with integration with other systems to make a unified management tool to run an organization.</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Worked on custom Laravel application which was multitenant with custom drag and drop theme system</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Built custom Zendesk applications for the Marketplace and scaled application infrastructure to handle high data volumes using cloud technology.</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Leveraged AWS services (Lambda, DynamoDB, SQS, EC2) to maintain and evolve a high-data-volume product with continuous feature delivery.</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Led and onboarded a development team, guiding members throughout the full product development lifecycle.</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Collaborated with a highly skilled Australian team on a Blockchain-based product as a Frontend Engineer, delivering features using Test-Driven Development (TDD).</span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Junior Role / Associate -->
                        <div class="relative pl-0 md:pl-24 group journey-item">
                            <div class="absolute left-6 top-8 w-5 h-5 rounded-full bg-surface ring-[6px] ring-slate-400/50 z-10 hidden md:block journey-node transition-all duration-300 group-hover:scale-125 group-hover:ring-slate-400"></div>
                            
                            <div class="bg-surface-container-low rounded-3xl p-8 md:p-10 border border-transparent hover:border-slate-400/20 transition-all duration-500 hover:shadow-2xl hover:shadow-slate-400/5 hover:-translate-y-1 relative overflow-hidden">
                                <div class="absolute top-0 right-0 w-32 h-32 bg-slate-400/5 rounded-bl-full -z-10 transition-transform group-hover:scale-110 duration-500"></div>
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
                                    <div>
                                        <h3 class="font-headline text-2xl font-bold text-on-surface">Web Developer</h3>
                                        <p class="font-label text-base text-slate-400 font-bold mt-1">Proshore Nepal</p>
                                    </div>
                                    <span class="font-label text-on-surface-variant font-bold text-xs bg-surface-container-highest px-4 py-2 rounded-full uppercase tracking-wider self-start sm:self-auto border border-surface-container-highest">March 2013 — Feb 2014</span>
                                </div>
                                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                                    Began my career building sites on a custom CodeIgniter framework, delivering numerous agency projects. Progressively transitioned to WordPress for faster client delivery, developing custom themes and plugins tailored to each site's specific needs.
                                </p>
                                <ul class="space-y-4 font-body text-on-surface-variant">
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-slate-400 bg-slate-400/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Integrated custom backends and Content Management Systems for designs across <span class="text-primary font-semibold">more than 30 client sites</span></span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-slate-400 bg-slate-400/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Transitioned to <span class="text-primary font-semibold">WordPress</span>, building custom themes from scratch and developing plugins to address each site's unique requirements</span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-slate-400 bg-slate-400/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Built custom web application using <span class="text-primary font-semibold">CakePHP</span></span>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="material-symbols-outlined text-slate-400 bg-slate-400/10 p-1 rounded-full text-sm mt-0.5">check</span>
                                        <span>Used templating engines to build custom themes for SaaS applications</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Education & Community Leadership -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="bg-surface-container-low p-10 rounded-xl border border-transparent hover:border-slate-200 transition-all duration-300">
                    <span class="font-label text-xs font-bold text-primary mb-6 block uppercase tracking-widest">Academic Foundation</span>
                    <h2 class="font-headline text-3xl font-bold mb-6">Education</h2>
                    <div class="space-y-6">
                        <div>
                            <h3 class="text-xl font-bold">St. Xavier's College, Kathmandu</h3>
                            <p class="text-on-surface-variant">Bachelors in Information Management (BIM)</p>
                            <p class="text-sm font-label text-tertiary">2011 — 2015</p>
                        </div>
                    </div>
                    <div class="pt-8 mt-8 border-t border-slate-200">
                        <span class="font-label text-xs font-bold text-on-surface-variant mb-4 block uppercase tracking-widest">Languages</span>
                        <div class="flex flex-wrap gap-3">
                            <span class="px-3 py-1 bg-surface-container-highest rounded text-sm">Nepali (Native)</span>
                            <span class="px-3 py-1 bg-surface-container-highest rounded text-sm">English (Professional)</span>
                            <span class="px-3 py-1 bg-surface-container-highest rounded text-sm">Hindi (Conversational)</span>
                        </div>
                    </div>
                </div>
                <div class="bg-surface-container-low p-10 rounded-xl border border-transparent hover:border-slate-200 transition-all duration-300">
                    <span class="font-label text-xs font-bold text-tertiary mb-6 block uppercase tracking-widest">Beyond the Screen</span>
                    <h2 class="font-headline text-3xl font-bold mb-6">Community & Leadership</h2>
                    <ul class="space-y-6 text-on-surface-variant">
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary mt-1">groups</span>
                            <div>
                                <h4 class="font-bold text-on-surface">BarCamp Kathmandu</h4>
                                <p class="text-sm">Lead Organizer for 2024 & 2025 editions, fostering the local tech community.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary mt-1">record_voice_over</span>
                            <div>
                                <h4 class="font-bold text-on-surface">WordCamp Speaker</h4>
                                <p class="text-sm">Regular speaker on SaaS integrations and Shopify engineering at official WordPress events.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary mt-1">hub</span>
                            <div>
                                <h4 class="font-bold text-on-surface">Zendesk Community</h4>
                                <p class="text-sm">Active contributor in official Slack channels and developer forums.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Core Expertise Bento Grid -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal">
            <h2 class="font-headline text-3xl font-bold mb-12 flex items-center gap-3">
                <span class="w-12 h-[2px] bg-primary"></span> Core Competencies
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Shopify Card -->
                <div class="bg-surface-container-low p-10 rounded-xl flex flex-col justify-between hover:bg-surface-container-lowest transition-colors duration-300 min-h-[400px] border border-transparent hover:border-slate-200">
                    <div>
                        <span class="font-label text-xs font-bold text-tertiary mb-6 block">E-COMMERCE ECOSYSTEMS</span>
                        <h3 class="font-headline text-4xl font-bold mb-4 tracking-tight">Shopify Specialist</h3>
                        <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                            From Shopify App Development to Theme Customization and SEO optimization. Building scalable e-commerce ecosystems engineered to deliver measurable, high-impact results.
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-4">
                        <span class="px-4 py-2 bg-surface-container-highest rounded-lg font-label text-sm text-on-surface">App Development</span>
                        <span class="px-4 py-2 bg-surface-container-highest rounded-lg font-label text-sm text-on-surface">Liquid</span>
                        <span class="px-4 py-2 bg-surface-container-highest rounded-lg font-label text-sm text-on-surface">SEO</span>
                    </div>
                </div>

                <!-- Zendesk Card -->
                <div class="bg-primary kinetic-gradient p-10 rounded-xl text-on-primary flex flex-col justify-between min-h-[400px]">
                    <div>
                        <span class="font-label text-xs font-bold opacity-80 mb-6 block uppercase">CX ARCHITECTURE</span>
                        <h3 class="font-headline text-4xl font-bold mb-4 tracking-tight">Zendesk Solution Architect</h3>
                        <p class="opacity-90 leading-relaxed mb-8">
                            Optimizing support workflows through process audits and targeted engineering. Building custom Zendesk apps that seamlessly bridge your existing systems with APIs and AI.
                        </p>
                    </div>
                    <div class="flex flex-col gap-6">
                        <div class="flex flex-wrap gap-4">
                            <span class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg font-label text-sm">CX Strategy</span>
                            <span class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg font-label text-sm">Zendesk Apps</span>
                            <span class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg font-label text-sm">API & AI</span>
                        </div>
                    </div>
                </div>

                <!-- Full Stack Card — replaced by full skills section below -->
            </div>
        </section>

        <!-- Full Technical Arsenal -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal">
            <div class="relative bg-inverse-surface rounded-2xl overflow-hidden shadow-2xl">
                <!-- Glowing top accent -->
                <div class="h-1 w-full bg-gradient-to-r from-primary via-tertiary to-secondary"></div>

                <div class="p-10 md:p-14">
                    <!-- Header -->
                    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
                        <div>
                            <span class="font-label text-xs font-bold text-tertiary uppercase tracking-[0.3em] mb-3 block">Complete Skill Set</span>
                            <h2 class="font-headline text-4xl md:text-5xl font-black text-white leading-tight">Technical Arsenal</h2>
                        </div>
                        <p class="text-slate-400 max-w-sm text-sm leading-relaxed">
                            A comprehensive view of every technology, platform, and discipline I bring to the table — across {experienceYears}+ years of engineering.
                        </p>
                    </div>

                    <!-- Overview Level -->
                    <div class="mb-10">
                        <div class="flex flex-wrap gap-3 mb-8">
                            <span class="skill-tag skill-tag--primary">JavaScript / TypeScript</span>
                            <span class="skill-tag skill-tag--tertiary">React & Next.js</span>
                            <span class="skill-tag skill-tag--secondary">PHP / Laravel</span>
                            <span class="skill-tag skill-tag--green">Zendesk Apps & API</span>
                            <span class="skill-tag skill-tag--amber">AWS & Cloud Infrastructure</span>
                            <span class="skill-tag skill-tag--pink">Shopify Development</span>
                        </div>
                        
                        <button id="toggle-arsenal" class="font-label text-sm font-bold text-white bg-white/5 hover:bg-white/10 border border-white/10 px-6 py-3 rounded-xl transition-all flex items-center gap-2">
                            <span id="toggle-arsenal-text">View Exhaustive List</span>
                            <span class="material-symbols-outlined text-lg transition-transform duration-300" id="toggle-arsenal-icon">expand_more</span>
                        </button>
                    </div>

                    <!-- Skill Categories Grid (Hidden by default) -->
                    <div id="arsenal-list" class="space-y-10 pt-8 border-t border-white/10 hidden">

                        <!-- Core Languages -->
                        <div class="skill-row group">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="material-symbols-outlined text-primary text-xl" data-icon="code">code</span>
                                <h3 class="font-label text-xs font-bold text-primary uppercase tracking-widest">Core Languages</h3>
                                <div class="flex-1 h-px bg-slate-700"></div>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                {["HTML", "CSS", "PHP", "JavaScript", "TypeScript", "JSON", "Python"].map(skill => (
                                    <span class="skill-tag skill-tag--primary">{skill}</span>
                                ))}
                            </div>
                        </div>

                        <!-- Frameworks & CMS -->
                        <div class="skill-row group">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="material-symbols-outlined text-tertiary text-xl" data-icon="layers">layers</span>
                                <h3 class="font-label text-xs font-bold text-tertiary uppercase tracking-widest">Frameworks & CMS</h3>
                                <div class="flex-1 h-px bg-slate-700"></div>
                            </div>
                            <div class="flex flex-wrap gap-2">
