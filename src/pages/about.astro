    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(ScrollTrigger);

            // Animate timeline line drawing down
            gsap.fromTo(".timeline-line",
                { scaleY: 0 },
                {
                    scaleY: 1,
                    transformOrigin: "top center",
                    ease: "none",
                    scrollTrigger: {
                        trigger: ".timeline-line",
                        start: "top 60%",
                        end: "bottom 20%",
                        scrub: true
                    }
                }
            );

            // Animate each journey item separately for a better scroll experience
            gsap.utils.toArray(".journey-item").forEach((item, i) => {
                const node = item.querySelector('.journey-node');
                
                // Animate the card
                gsap.fromTo(item,
                    { opacity: 0, y: 30 },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: item,
                            start: "top 85%",
                        }
                    }
                );
                
                // Animate the timeline node
                if (node) {
                    gsap.fromTo(node,
                        { scale: 0, opacity: 0 },
                        {
                            scale: 1,
                            opacity: 1,
                            duration: 0.5,
                            ease: "back.out(2)",
                            scrollTrigger: {
                                trigger: item,
                                start: "top 85%",
                            }
                        }
                    );
                }
            });

            // Arsenal Learn More Toggle
            const toggleArsenalBtn = document.getElementById("toggle-arsenal");
            const arsenalList = document.getElementById("arsenal-list");
            const toggleText = document.getElementById("toggle-arsenal-text");
            const toggleIcon = document.getElementById("toggle-arsenal-icon");

            if (toggleArsenalBtn && arsenalList) {
                toggleArsenalBtn.addEventListener("click", () => {
                    const isHidden = arsenalList.classList.contains("hidden");
                    
                    if (isHidden) {
                        arsenalList.classList.remove("hidden");
                        gsap.fromTo(arsenalList,
                            { height: 0, opacity: 0 },
                            { 
                                height: "auto", 
                                opacity: 1, 
                                duration: 0.6, 
                                ease: "power3.out",
                                onComplete: () => ScrollTrigger.refresh() 
                            }
                        );
                        toggleText.textContent = "Hide Exhaustive List";
                        toggleIcon.classList.add("rotate-180");
                    } else {
                        gsap.to(arsenalList, {
                            height: 0,
                            opacity: 0,
                            duration: 0.4,
                            ease: "power2.in",
                            onComplete: () => {
                                arsenalList.classList.add("hidden");
                                ScrollTrigger.refresh();
                            }
                        });
                        toggleText.textContent = "View Exhaustive List";
                        toggleIcon.classList.remove("rotate-180");
                    }
                });
            }
        });
    </script>
