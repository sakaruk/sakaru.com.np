---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Sakar | Zendesk Expert & Shopify Engineer (10+ Years Experience)">
    <main class="pt-24 pb-20 max-w-7xl mx-auto px-8 w-full overflow-hidden">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <div class="lg:col-span-7">
                    <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-4 block">10+ Years of Engineering Excellence</span>
                    <h1 class="font-headline text-6xl md:text-7xl font-extrabold tracking-tighter leading-tight mb-8">
                        Zendesk Developer & <span class="text-primary italic">Shopify</span> Engineer.
                    </h1>
                    <p class="font-body text-xl text-on-surface-variant leading-relaxed max-w-2xl">
                        Based in Nepal, I build custom solutions for global clients like <span class="text-primary font-semibold">Stylo</span>, <span class="text-primary font-semibold">ClickSend</span>, and <span class="text-primary font-semibold">ApplyBoard</span>. I specialize in complex SaaS integrations, custom Zendesk Marketplace apps, and high-performance Shopify Plus engineering.
                    </p>
                </div>
                <div class="lg:col-span-5 relative group">
                    <div class="absolute -inset-4 bg-primary-fixed rounded-xl opacity-20 group-hover:opacity-30 transition-opacity"></div>
                    <img alt="Sakar Upadhyaya Khatiwada" class="relative w-full aspect-square object-cover rounded-xl grayscale hover:grayscale-0 transition-all duration-500 shadow-xl" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBUuc8cvQuzZjxkCfLk3dj5U70hCdg2Lm9m-ykOYRGrtc25agQC9Wzl-gNiifxRpS_f-_ZILIJB_FnOmg0Cxax4R0JTZSEsf2j_uQ2EAGO0nQ346Li_RNBh1cPZEeL7NsPeYKJFs4v_NgdaJbs92v6iehaoEALWmqTxXEfSwbyE6KYbs4IJg185jy80dOcM_kyrRDJHdRq4qyw-cKg7uikwjjYE5y53KuKStYaTSI1TqUEhtXC32wA5LBtCzaByc_P7C9GsTupb7hGP"/>
                </div>
            </div>
        </section>

        <!-- Core Expertise Bento Grid -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal">
            <h2 class="font-headline text-3xl font-bold mb-12 flex items-center gap-3">
                <span class="w-12 h-[2px] bg-primary"></span> Core Competencies
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Shopify Card -->
                <div class="bg-surface-container-low p-10 rounded-xl flex flex-col justify-between hover:bg-surface-container-lowest transition-colors duration-300 min-h-[400px] border border-transparent hover:border-slate-200">
                    <div>
                        <span class="font-label text-xs font-bold text-tertiary mb-6 block">E-COMMERCE ARCHITECTURE</span>
                        <h3 class="font-headline text-4xl font-bold mb-4 tracking-tight">Shopify Ecosystem Specialist</h3>
                        <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                            Developing robust, high-conversion headless commerce experiences and bespoke private apps that extend the core capabilities of Shopify Plus.
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-4">
                        <span class="px-4 py-2 bg-surface-container-highest rounded-lg font-label text-sm text-on-surface">Polaris UI</span>
                        <span class="px-4 py-2 bg-surface-container-highest rounded-lg font-label text-sm text-on-surface">Liquid</span>
                        <span class="px-4 py-2 bg-surface-container-highest rounded-lg font-label text-sm text-on-surface">Remix</span>
                    </div>
                </div>

                <!-- Zendesk Card -->
                <div class="bg-primary kinetic-gradient p-10 rounded-xl text-on-primary flex flex-col justify-between min-h-[400px]">
                    <div>
                        <span class="font-label text-xs font-bold opacity-80 mb-6 block uppercase">CX INTEGRATION</span>
                        <h3 class="font-headline text-4xl font-bold mb-4 tracking-tight">Zendesk Expert</h3>
                        <p class="opacity-90 leading-relaxed mb-8">
                            Deep-tier integrations connecting support workflows directly into product ecosystems via custom Zendesk Apps and API middleware.
                        </p>
                    </div>
                    <div class="flex flex-col gap-6">
                        <div class="flex flex-wrap gap-4">
                            <span class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg font-label text-sm">Zendesk Apps</span>
                            <span class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg font-label text-sm">ZAF Client</span>
                            <span class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg font-label text-sm">Sunshine</span>
                        </div>
                    </div>
                </div>

                <!-- Full Stack Card -->
                <div class="bg-inverse-surface p-10 rounded-xl text-inverse-on-surface md:col-span-2 flex flex-col md:flex-row gap-12 items-center">
                    <div class="flex-1">
                        <span class="font-label text-xs font-bold text-tertiary-fixed-dim mb-6 block">TECHNICAL STACK</span>
                        <h3 class="font-headline text-4xl font-bold mb-4">Enterprise Full-Stack Mastery</h3>
                        <p class="text-slate-400 text-lg leading-relaxed">
                            Leveraging Node.js, React, and Laravel to build distributed systems that prioritize security, uptime, and developer ergonomics.
                        </p>
                    </div>
                    <div class="grid grid-cols-2 gap-4 flex-1 w-full text-slate-300">
                        <div class="bg-slate-800 p-4 rounded-lg flex items-center gap-3">
                            <span class="font-label">Node.js</span>
                        </div>
                        <div class="bg-slate-800 p-4 rounded-lg flex items-center gap-3">
                            <span class="font-label">React</span>
                        </div>
                        <div class="bg-slate-800 p-4 rounded-lg flex items-center gap-3">
                            <span class="font-label">Laravel</span>
                        </div>
                        <div class="bg-slate-800 p-4 rounded-lg flex items-center gap-3">
                            <span class="font-label">PostgreSQL</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Professional Journey Timeline Section -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                <div class="lg:col-span-4">
                    <h2 class="font-headline text-4xl font-extrabold sticky top-32">Professional <br/>Journey</h2>
                </div>
                <div class="lg:col-span-8 relative">
                    <!-- Timeline Line -->
                    <div class="absolute left-0 md:left-6 top-2 bottom-0 w-px timeline-line hidden md:block origin-top"></div>
                    
                    <div class="space-y-16">
                        <!-- Senior Role -->
                        <div class="relative pl-0 md:pl-16 group gsap-stagger">
                            <div class="absolute left-5 top-2 w-3 h-3 rounded-full bg-primary ring-4 ring-primary-fixed hidden md:block"></div>
                            <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-4 gap-2">
                                <div>
                                    <h3 class="font-headline text-2xl font-bold">Senior Software Engineer</h3>
                                    <p class="font-label text-sm text-tertiary font-bold">Stylo (US)</p>
                                </div>
                                <span class="font-label text-primary font-bold text-sm bg-primary-fixed px-3 py-1 rounded-full whitespace-nowrap">2021 — PRESENT</span>
                            </div>
                            <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                                Leading engineering for <span class="text-primary font-semibold">Stylo's Zendesk AI integrations</span>. Architecting distributed systems that connect multi-platform support data into unified AI-driven workflows for global enterprise clients.
                            </p>
                            <ul class="space-y-4 font-body text-on-surface-variant">
                                <li class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-primary text-xl mt-1">check_circle</span>
                                    <span>Engineered the <span class="text-primary font-semibold">Stylo Assist App</span> (ZAF Client + React), now a key AI solution in the Zendesk Marketplace.</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-primary text-xl mt-1">check_circle</span>
                                    <span>Built custom middleware for <span class="text-primary font-semibold">ClickSend Australia</span> and <span class="text-primary font-semibold">ApplyBoard Canada</span> streamlining CX across timezones.</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-primary text-xl mt-1">check_circle</span>
                                    <span>Reduced specialized agent response times by 40% through automated ZIS and Sunshine integrations.</span>
                                </li>
                            </ul>
                        </div>

                        <!-- Full Stack Role -->
                        <div class="relative pl-0 md:pl-16 group gsap-stagger">
                            <div class="absolute left-5 top-2 w-3 h-3 rounded-full bg-slate-300 ring-4 ring-slate-100 hidden md:block"></div>
                            <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-4 gap-2">
                                <div>
                                    <h3 class="font-headline text-2xl font-bold">Full Stack Developer</h3>
                                    <p class="font-label text-sm text-tertiary font-bold">Proshore Nepal</p>
                                </div>
                                <span class="font-label text-secondary font-bold text-sm bg-secondary-fixed px-3 py-1 rounded-full whitespace-nowrap">2018 — 2021</span>
                            </div>
                            <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                                Developed and optimized high-traffic SaaS applications for European and North American clients, focusing on Laravel backends and React frontends.
                            </p>
                            <ul class="space-y-4 font-body text-on-surface-variant">
                                <li class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-slate-400 text-xl mt-1">check_circle</span>
                                    <span>Led headless Shopify engineering for <span class="text-primary font-semibold">Barlife Denmark</span>, improving mobile core web vitals by 60%.</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-slate-400 text-xl mt-1">check_circle</span>
                                    <span>Architected real-time analytics for subscription platforms using Node.js and PostgreSQL.</span>
                                </li>
                            </ul>
                        </div>

                        <!-- Junior Role / Associate -->
                        <div class="relative pl-0 md:pl-16 group gsap-stagger">
                            <div class="absolute left-5 top-2 w-3 h-3 rounded-full bg-slate-300 ring-4 ring-slate-100 hidden md:block"></div>
                            <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-4 gap-2">
                                <div>
                                    <h3 class="font-headline text-2xl font-bold">Software Developer</h3>
                                    <p class="font-label text-sm text-tertiary font-bold">Digital Bridge</p>
                                </div>
                                <span class="font-label text-secondary font-bold text-sm bg-secondary-fixed px-3 py-1 rounded-full whitespace-nowrap">2016 — 2018</span>
                            </div>
                            <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                                Early career focus on custom CMS development and API integrations, gaining deep expertise in the JavaScript ecosystem and RESTful architecture.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Technical Fragments (Code Context) -->
        <section class="max-w-7xl mx-auto mb-48 gsap-reveal">
            <div class="bg-inverse-surface rounded-xl overflow-hidden shadow-2xl">
                <div class="bg-[#1e2433] px-6 py-3 flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                    <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                    <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
                    <span class="ml-4 font-label text-xs text-slate-500">manifesto.ts</span>
                </div>
                <div class="p-10 font-mono text-sm md:text-base overflow-x-auto text-on-primary">
                    <pre><code><span class="text-blue-300">const</span> <span class="text-blue-200">EngineeringPhilosophy</span> = {'{'}
  <span class="text-blue-300">resilience</span>: <span class="text-white">"Build for the 1% failure state, not the 99% success."</span>,
  <span class="text-blue-300">precision</span>: <span class="text-white">"Code is written for humans to read and machines to execute."</span>,
  <span class="text-blue-300">integration</span>: <span class="text-white">"Software should feel like an invisible thread connecting user intent to result."</span>
{'}'};

<span class="text-blue-300">export default</span> <span class="text-blue-200">Sakar</span>;</code></pre>
                </div>
            </div>
        </section>
        <!-- Final CTA / Contact Anchor -->
        <section class="max-w-7xl mx-auto px-8 py-32 bg-primary-fixed/30 rounded-[3rem] text-center mb-10 gsap-reveal">
            <div class="max-w-3xl mx-auto">
                <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-6 block">Ready for the Next Phase?</span>
                <h2 class="font-headline text-5xl md:text-6xl font-extrabold text-on-primary-fixed mb-10 leading-tight">Let's discuss high-value engineering.</h2>
                <p class="text-on-primary-fixed-variant text-xl mb-12 leading-relaxed">
                    Currently available for senior architectural consultations and complex platform integrations. Whether you're scaling a Shopify Plus store or streamlining CX via Zendesk, let's build something resilient.
                </p>
                <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
                    <button class="w-full sm:w-auto bg-primary text-on-primary font-headline font-bold py-5 px-12 rounded-2xl transition-all hover:scale-105 hover:shadow-xl active:scale-95">
                        Inquire via Email
                    </button>
                    <a class="w-full sm:w-auto font-headline font-bold text-primary hover:text-primary-variant transition-colors py-5 px-12" href="#">
                        LinkedIn Profile
                    </a>
                </div>
            </div>
        </section>
    </main>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(ScrollTrigger);

            // Animate individual timeline elements staggering in
            gsap.fromTo(".gsap-stagger", 
                { opacity: 0, x: -20 },
                { 
                    opacity: 1, 
                    x: 0, 
                    stagger: 0.2,
                    duration: 0.8,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: ".timeline-line", // Use the timeline as the trigger zone
                        start: "top 75%",
                    }
                }
            );

            // Animate timeline drawing down
            gsap.fromTo(".timeline-line",
                { scaleY: 0 },
                {
                    scaleY: 1,
                    transformOrigin: "top center",
                    ease: "none",
                    scrollTrigger: {
                        trigger: ".timeline-line",
                        start: "top 50%",
                        end: "bottom 30%",
                        scrub: true
                    }
                }
            );

            // Animate circles pop-in on the timeline
            gsap.fromTo(".rounded-full.ring-4",
                { scale: 0, opacity: 0 },
                {
                    scale: 1,
                    opacity: 1,
                    duration: 0.5,
                    stagger: 0.4,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: ".timeline-line",
                        start: "top 60%",
                    }
                }
            );
        });
    </script>
</BaseLayout>
