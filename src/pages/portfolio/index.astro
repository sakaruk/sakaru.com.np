---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Professional Portfolio | Zendesk App Developer">
    <main class="pt-24 pb-20 max-w-7xl mx-auto px-8 w-full">
        <!-- Hero Section -->
        <section class="max-w-4xl mx-auto mb-32 text-center gsap-reveal">
            <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-4 block">Proven Implementations</span>
            <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-tight mb-8">
                Selected <span class="text-primary italic">Works</span> & App Ecosystems.
            </h1>
            <p class="font-body text-xl text-on-surface-variant leading-relaxed">
                A showcase of custom Zendesk Marketplace applications and platform integrations built for global scale.
            </p>
        </section>

        <!-- Portfolio Grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-32">
            <!-- Stylo Assist -->
            <div class="group gsap-reveal">
                <div class="aspect-video bg-surface-container-high rounded-3xl mb-8 overflow-hidden relative border border-transparent group-hover:border-primary/30 transition-all duration-500">
                    <div class="absolute inset-0 bg-primary opacity-5 group-hover:opacity-10 transition-opacity"></div>
                    <div class="absolute inset-0 flex items-center justify-center p-12">
                        <span class="font-headline text-6xl font-black text-primary/10 select-none">STYLO</span>
                    </div>
                </div>
                <div class="px-4">
                    <span class="font-label text-xs font-bold text-primary mb-3 block uppercase tracking-widest">Zendesk Marketplace App</span>
                    <h2 class="font-headline text-3xl font-bold mb-4 group-hover:text-primary transition-colors">Stylo Assist AI</h2>
                    <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                        An AI-driven assistant for Zendesk agents built with TypeScript and React. Leverages GPT models to provide real-time sentiment analysis and response suggestions.
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">TypeScript</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">React</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">Tailwind</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">ZAF Client</span>
                    </div>
                </div>
            </div>

            <!-- ClickSend -->
            <div class="group gsap-reveal">
                <div class="aspect-video bg-surface-container-high rounded-3xl mb-8 overflow-hidden relative border border-transparent group-hover:border-primary/30 transition-all duration-500">
                    <div class="absolute inset-0 bg-secondary opacity-5 group-hover:opacity-10 transition-opacity"></div>
                    <div class="absolute inset-0 flex items-center justify-center p-12">
                        <span class="font-headline text-6xl font-black text-secondary/10 select-none">CLICKSEND</span>
                    </div>
                </div>
                <div class="px-4">
                    <span class="font-label text-xs font-bold text-secondary mb-3 block uppercase tracking-widest">SMS Integration</span>
                    <h2 class="font-headline text-3xl font-bold mb-4 group-hover:text-secondary transition-colors">ClickSend for Zendesk</h2>
                    <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                        Bridging customer support and mobile engagement. A custom Zendesk app allowing agents to send and receive SMS directly within tickets via the ClickSend API.
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">Node.js</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">ZAF Client</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">REST API</span>
                    </div>
                </div>
            </div>

            <!-- Google My Business -->
            <div class="group gsap-reveal">
                <div class="aspect-video bg-surface-container-high rounded-3xl mb-8 overflow-hidden relative border border-transparent group-hover:border-primary/30 transition-all duration-500">
                    <div class="absolute inset-0 bg-tertiary opacity-5 group-hover:opacity-10 transition-opacity"></div>
                    <div class="absolute inset-0 flex items-center justify-center p-12">
                        <span class="font-headline text-6xl font-black text-tertiary/10 select-none">GMB</span>
                    </div>
                </div>
                <div class="px-4">
                    <span class="font-label text-xs font-bold text-tertiary mb-3 block uppercase tracking-widest">Enterprise Integration</span>
                    <h2 class="font-headline text-3xl font-bold mb-4 group-hover:text-tertiary transition-colors">GMB to Zendesk Sync</h2>
                    <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                        High-traffic integration for PlusCloud clients. Syncing Google My Business reviews and messages into Zendesk tickets using a Laravel-based middleware.
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">Laravel</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">OAuth 2.0</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">MySQL</span>
                    </div>
                </div>
            </div>

            <!-- Quark AI -->
            <div class="group gsap-reveal">
                <div class="aspect-video bg-surface-container-high rounded-3xl mb-8 overflow-hidden relative border border-transparent group-hover:border-primary/30 transition-all duration-500">
                    <div class="absolute inset-0 bg-primary opacity-5 group-hover:opacity-10 transition-opacity"></div>
                    <div class="absolute inset-0 flex items-center justify-center p-12">
                        <span class="font-headline text-6xl font-black text-primary/10 select-none">QUARK AI</span>
                    </div>
                </div>
                <div class="px-4">
                    <span class="font-label text-xs font-bold text-primary mb-3 block uppercase tracking-widest">Early AI Integration</span>
                    <h2 class="font-headline text-3xl font-bold mb-4 group-hover:text-primary transition-colors">Quark AI Legacy App</h2>
                    <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                        Custom Zendesk implementation featuring legacy support and jQuery-based framework integration. Focused on knowledge base automation and predictive ticket routing.
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">jQuery</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">Webpack</span>
                        <span class="px-3 py-1 bg-surface-container-highest rounded-full font-label text-xs">ZCLI</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="max-w-4xl mx-auto px-8 py-20 bg-primary-fixed/30 rounded-[3rem] text-center mb-10 gsap-reveal">
            <h2 class="font-headline text-4xl font-extrabold mb-8">Need a custom integration?</h2>
            <p class="text-on-primary-fixed-variant text-xl mb-12">
                I help enterprises and startups build robust links between their product and customer support. Let's build your next app.
            </p>
            <a href="/services" class="inline-block bg-primary text-on-primary font-headline font-bold py-4 px-12 rounded-2xl hover:scale-105 transition-all">
                Explore My Services
            </a>
        </section>
    </main>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(ScrollTrigger);
            gsap.utils.toArray(".gsap-reveal").forEach((section) => {
                gsap.from(section, {
                    opacity: 0,
                    y: 40,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: section,
                        start: "top 85%",
                    }
                });
            });
        });
    </script>
</BaseLayout>
