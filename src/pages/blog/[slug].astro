---
export async function getStaticPaths() {
  const posts = import.meta.glob('../../../data/blog/*.md', { eager: true });
  
  return Object.values(posts).map((post: any) => {
    // Extract slug from the filepath (e.g. filename without .md)
    const filepath = post.file;
    const slug = filepath.split('/').pop().replace('.md', '');
    
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
---

<!-- Render exactly what the component exported implicitly! -->
<post.default />
