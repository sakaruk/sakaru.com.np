---
import BaseLayout from '../layouts/BaseLayout.astro';

const talks = [
    {
        title: "Coz Speed Matters",
        description: "A deep dive into why website speed is a non-negotiable in today's digital world — and exactly what you can do about it in WordPress.",
        type: "Talk / Optimization",
        thumbnail: "https://videos.files.wordpress.com/RDX0xriJ/video-59ec50136c_scruberthumbnail_0.jpg",
        video_url: "https://wordpress.tv/2015/03/10/sakar-upadhyaya-khatiwada-because-website-speed-matters/",
        slides_url: "https://www.slideshare.net/slideshow/coz-speed-matters-wordpress-optimization/41890594"
    },
    {
        title: "Accessible WordPress(ing)",
        description: "An eye-opening look at web accessibility and practical steps to make your WordPress site welcoming and usable for everyone, regardless of ability.",
        type: "Talk / Accessibility",
        thumbnail: "https://videos.files.wordpress.com/ZxhTd5hN/video-ad805490ad_scruberthumbnail_0.jpg",
        video_url: "https://wordpress.tv/2015/12/30/sakar-upadhyaya-khatiwada-accessible-wordpressing/",
        slides_url: "https://www.slideshare.net/slideshow/accessible-wordpressing/55362625"
    },
    {
        title: "Soft skill toppings for spicing up your WordPress professionalism",
        description: "Technical skills get you in the room — soft skills keep you there. This session explores the communication, collaboration, and professional habits that set great WordPress professionals apart from the rest.",
        type: "Talk / Soft Skills",
        thumbnail: "https://videos.files.wordpress.com/81YlrOoV/video-888f1944a4_scruberthumbnail_1.jpg",
        video_url: "https://wordpress.tv/2018/05/05/sakar-upadhyaya-khatiwada-soft-skill-toppings-for-spicing-up-your-wordpress-professionalism/",
    },
    {
        title: "Thinking the React Way for WordPress Developers",
        description: "A PHP developer's guide to thinking in React — building the mental models needed to confidently create Gutenberg Blocks and Full Site Editing components.",
        type: "Talk / React & WordPress",
        thumbnail: "https://videos.files.wordpress.com/T8GpaCak/video-28354b5f96_mp4.scrubthumb.jpg",
        video_url: "https://wordpress.tv/2022/10/01/thinking-the-react-way-for-wordpress-developers/",
    },
    {
        title: "Dissecting WordPress Playground",
        description: "A lightning-fast exploration of WordPress Playground — what it is, what you can build with it, and why every WordPress developer should be paying attention.",
        type: "Lightning Talk",
        thumbnail: "https://videos.files.wordpress.com/FVjSjW6V/video-4d756dc6b9_mp4.scrubthumb.jpg",
        video_url: "https://wordpress.tv/2025/04/30/dissecting-wordpress-playground/",
    }
];

const communityContributions = [
    {
        title: "Web Weekend Kathmandu",
        description: "Part of the organizing team behind Tech Kura Kani, AI Conf 2026, and BarCamp Kathmandu 2024 & 2025 — events designed to spark conversations, build connections, and grow the local tech community.",
        icon: "groups",
        colorClass: "tertiary",
        link: {
            url: "https://community.wwktm.com/",
            label: "Join The Community"
        }
    },
    {
        title: "WordCamp Speaker",
        description: "Bridging core web concepts with the WordPress ecosystem through talks that make complex ideas approachable — from performance and accessibility to React and the Block Editor.",
        icon: "record_voice_over",
        colorClass: "tertiary",
        link: {
            url: "https://wordpress.tv/speakers/sakar-upadhyaya-khatiwada/",
            label: "Watch Videos"
        }
    },
    {
        title: "Community Supporter",
        description: "Deeply embedded in developer communities both in Kathmandu and online — always attending, always learning, always sharing. Previously organized the PHP Developers Meetup and Shopify Meetup in Nepal.",
        icon: "hub",
        colorClass: "tertiary",
    },
    {
        title: "Open Source Contributor",
        description: "Actively developing and maintaining open-source tools and repositories under SaaSPal, contributing back to the ecosystem that has given so much.",
        icon: "code",
        colorClass: "tertiary",
        link: {
            url: "https://github.com/saaspal",
            label: "View GitHub Profile"
        }
    }
];
---

<BaseLayout 
    title="Community & Public Speaking | Sakar Upadhyaya Khatiwada"
    description="Sakar Upadhyaya Khatiwada is a tech community builder in Nepal — co-organizer of AI Conf 2026, BarCamp Kathmandu, and Web Weekend Kathmandu, and a WordCamp speaker with talks on WordPress performance, accessibility, React, and more."
>
    <main class="pt-24 pb-20 max-w-7xl mx-auto px-8">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto mb-32 gsap-reveal pt-20">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <div class="lg:col-span-7">
                    <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-4 block">Community Builder & Tech Speaker</span>
                    <h1 class="font-headline text-6xl md:text-7xl font-extrabold tracking-tighter leading-tight mb-8">
                        Fostering <span class="text-primary italic">Community & Knowledge</span>
                    </h1>
                    <p class="font-body text-xl text-on-surface-variant leading-relaxed max-w-2xl">
                        Engineering is my craft, but community is my passion. From co-organizing <span class="text-primary font-bold">AI Conf 2026</span> and <span class="text-primary font-bold">BarCamp Kathmandu</span> to speaking on stages at <span class="text-primary font-bold">WordCamps</span>, I'm committed to growing the <span class="text-primary font-semibold">Nepali tech ecosystem</span> — one event, one talk, and one connection at a time.
                    </p>
                </div>
                <div class="lg:col-span-5 relative group">
                    <img 
                        alt="Sakar Upadhyaya Khatiwada Speaking at a Tech Event" 
                        class="relative w-full aspect-square object-cover rounded-xl grayscale hover:grayscale-0 transition-all duration-500 shadow-xl" 
                        src="/images/speaker.jpg"
                    />
                </div>
            </div>
        </section>

        <!-- Community Contributions Section -->
        <section class="mb-32 gsap-reveal">
            <h2 class="text-4xl md:text-5xl font-headline font-black text-on-surface mb-12">Community Leadership</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {communityContributions.map((item) => (
                    <div class={`bg-surface-container-low p-10 rounded-3xl border border-transparent hover:border-${item.colorClass}/20 transition-all duration-300 shadow-xl shadow-${item.colorClass}/5 hover:-translate-y-1 flex flex-col`}>
                        <div class={`w-16 h-16 bg-${item.colorClass}/10 rounded-2xl flex items-center justify-center mb-6`}>
                            <span class={`material-symbols-outlined text-3xl text-${item.colorClass}`} data-icon={item.icon}>{item.icon}</span>
                        </div>
                        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">{item.title}</h3>
                        <p class="text-on-surface-variant leading-relaxed mb-6 flex-1">
                            {item.description}
                        </p>
                        {item.link && (
                            <a href={item.link.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-primary font-label font-bold text-sm uppercase tracking-widest hover:text-primary-variant transition-colors group mt-auto">
                                {item.link.label}
                                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" data-icon="open_in_new">open_in_new</span>
                            </a>
                        )}
                    </div>
                ))}
            </div>
        </section>

        <!-- Talks List Section -->
        <section class="mb-32">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-12 gsap-reveal">
                <div>
                    <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-4 block">Public Speaking</span>
                    <h2 class="text-4xl md:text-5xl font-headline font-black text-on-surface">Technical Talks</h2>
                </div>
                <p class="text-on-surface-variant max-w-md text-lg">
                    Sharing knowledge across stages — making tech more accessible, one room at a time.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {talks.map((talk: any) => (
                    <article class="group gsap-reveal bg-surface-container-low p-8 rounded-3xl border border-transparent hover:border-primary/20 transition-all duration-300 shadow-xl shadow-primary/5 hover:-translate-y-1 flex flex-col h-full">
                        <!-- Image/Thumbnail area -->
                        <div class="aspect-video bg-surface-container-high rounded-2xl mb-8 overflow-hidden relative block">
                            <a href={talk.video_url || talk.slides_url} target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-10"></a>
                            <img 
                                src={talk.thumbnail || "https://lh3.googleusercontent.com/aida-public/AB6AXuCr9HE521CGJX6vYPXdqO_8TbRlNO_T6N_G8Rb3AyGZZ1NgCsVo3iRAMdibCICthOQ3oP0VsjLAKw2UZ99fZFNo04mcC-IZW-zKaxo2ovefhFLxvOcJrTxW-Cl6GCWOxnB3Bbt8ntZCW9pEBEhl-Z6f8lLcm31W-VaZfAOW_NpaQwIVAIzjVVteqmfr-tTAoixHwAWdyd0nIN1RV9aJJi-7Wjftt5VZlnNS2h01UhLPmch1c-C-17f8CJLq8GPkmqmliIcDAkDiJ5HM"} 
                                alt={talk.title} 
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 relative z-0" 
                            />
                            <div class="absolute inset-0 bg-primary/10 mix-blend-overlay z-0"></div>
                        </div>
                        
                        <div class="flex flex-col flex-1">
                            <div class="flex items-center gap-3 mb-3">
                                <span class="font-label text-xs font-bold text-primary block uppercase tracking-widest">{talk.type || "Talk"}</span>
                                <span class="h-px w-4 bg-outline-variant"></span>
                            </div>
                            <h3 class="font-headline text-3xl font-bold mb-4 group-hover:text-primary transition-colors">
                                <a href={talk.video_url || talk.slides_url} target="_blank" rel="noopener noreferrer" class="relative z-10">{talk.title}</a>
                            </h3>
                            <p class="text-on-surface-variant text-lg leading-relaxed mb-6 flex-1">
                                {talk.description}
                            </p>
                            <div class="flex flex-wrap gap-4 relative z-10 mt-auto">
                                {talk.video_url && (
                                    <a href={talk.video_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-primary font-label font-bold text-sm hover:underline">
                                        <span class="material-symbols-outlined text-lg" data-icon="play_circle">play_circle</span>
                                        Watch Video
                                    </a>
                                )}
                                {talk.slides_url && (
                                    <a href={talk.slides_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-on-surface-variant font-label font-bold text-sm hover:text-on-surface hover:underline transition-colors">
                                        <span class="material-symbols-outlined text-lg" data-icon="auto_stories">auto_stories</span>
                                        Slides
                                    </a>
                                )}
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <!-- CTA Section -->
        <section class="mt-32 gsap-reveal">
            <div class="bg-gradient-to-br from-primary to-tertiary rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden shadow-2xl shadow-primary/20">
                <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-black/10 rounded-full blur-3xl"></div>
                
                <div class="relative z-10">
                    <span class="font-label text-sm uppercase tracking-widest text-on-primary/70 font-bold mb-6 block">Open to Collaboration</span>
                    <h2 class="text-4xl md:text-6xl font-headline font-black text-on-primary mb-8">
                        Speaker. Organizer. Collaborator.
                    </h2>
                    <p class="text-xl md:text-2xl text-on-primary/80 max-w-2xl mx-auto mb-12 font-body leading-relaxed">
                        Whether you need a speaker for your next event, a co-organizer for a community initiative, or just someone to bounce ideas off — I'm always happy to connect and build something together.
                    </p>
                    <a href="mailto:sakar@saaspal.us" class="inline-flex items-center gap-4 bg-surface-container-lowest text-primary px-10 py-5 rounded-full font-headline font-black text-xl hover:scale-105 active:scale-95 transition-transform shadow-xl">
                        Let's Connect
                        <span class="material-symbols-outlined font-bold" data-icon="mail">mail</span>
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

