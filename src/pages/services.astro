---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Professional Services | Zendesk & Shopify Specialist">
    <main class="pt-24 pb-20 max-w-7xl mx-auto px-8 w-full overflow-hidden">
        <!-- Hero Section -->
        <section class="max-w-4xl mx-auto mb-32 text-center gsap-reveal">
            <span class="font-label text-sm uppercase tracking-widest text-primary font-bold mb-4 block">Engineered for Scale</span>
            <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-tight mb-8">
                Specialized <span class="text-primary italic">Services</span> for Global SaaS Ecosystems.
            </h1>
            <p class="font-body text-xl text-on-surface-variant leading-relaxed">
                As a freelance consultant based in Nepal, I help businesses reduce friction and increase efficiency through high-tier technical implementations across the Zendesk and Shopify platforms.
            </p>
        </section>

        <!-- Services Grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-32 gsap-reveal">
            <!-- Zendesk Implementation -->
            <div class="bg-surface-container-low p-12 rounded-3xl border border-transparent hover:border-primary/20 transition-all duration-300 group">
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-primary transition-colors duration-300">
                    <span class="material-symbols-outlined text-primary group-hover:text-on-primary text-3xl">settings_applications</span>
                </div>
                <h2 class="font-headline text-3xl font-bold mb-6">Zendesk Implementation</h2>
                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                    Full-cycle Zendesk setup and optimization. I ensure your support environment is configured for maximum agent productivity and seamless customer experiences.
                </p>
                <ul class="space-y-3 text-on-surface-variant font-body">
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Workflow & Trigger Architecture</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Omnichannel Configuration</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span> AI Agent Deployment</li>
                </ul>
            </div>

            <!-- Custom App Development -->
            <div class="bg-surface-container-low p-12 rounded-3xl border border-transparent hover:border-secondary/20 transition-all duration-300 group">
                <div class="w-16 h-16 bg-secondary/10 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-secondary transition-colors duration-300">
                    <span class="material-symbols-outlined text-secondary group-hover:text-on-secondary text-3xl">terminal</span>
                </div>
                <h2 class="font-headline text-3xl font-bold mb-6">Custom Zendesk Apps</h2>
                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                    Building bespoke applications using the Zendesk Apps Framework (ZAF) to extend your support capabilities and integrate with your internal product data.
                </p>
                <ul class="space-y-3 text-on-surface-variant font-body">
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-secondary"></span> Side-bar & Top-bar Apps</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-secondary"></span> External API Integrations</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-secondary"></span> Complex Middleware Development</li>
                </ul>
            </div>

            <!-- Shopify Engineering -->
            <div class="bg-surface-container-low p-12 rounded-3xl border border-transparent hover:border-tertiary/20 transition-all duration-300 group">
                <div class="w-16 h-16 bg-tertiary/10 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-tertiary transition-colors duration-300">
                    <span class="material-symbols-outlined text-tertiary group-hover:text-on-tertiary text-3xl">shopping_cart</span>
                </div>
                <h2 class="font-headline text-3xl font-bold mb-6">Shopify Plus Engineering</h2>
                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                    High-performance commerce engineering including headless Hydrogen builds, custom private apps, and complex checkout extensions for Plus merchants.
                </p>
                <ul class="space-y-3 text-on-surface-variant font-body">
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-tertiary"></span> Headless Commerce (Remix/Hydrogen)</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-tertiary"></span> Custom Shopify App Development</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-tertiary"></span> ERP & Inventory Sync</li>
                </ul>
            </div>

            <!-- SaaS Integration -->
            <div class="bg-surface-container-low p-12 rounded-3xl border border-transparent hover:border-primary/20 transition-all duration-300 group">
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-primary transition-colors duration-300">
                    <span class="material-symbols-outlined text-primary group-hover:text-on-primary text-3xl">hub</span>
                </div>
                <h2 class="font-headline text-3xl font-bold mb-6">SaaS Strategy & Consulting</h2>
                <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                    Senior architectural consulting for businesses looking to unify their tech stack, streamline data flow, and reduce operational overhead through automation.
                </p>
                <ul class="space-y-3 text-on-surface-variant font-body">
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Tech Stack Audits</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Integration Roadmapping</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Automation Efficiency Analysis</li>
                </ul>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="max-w-4xl mx-auto px-8 py-20 bg-inverse-surface rounded-[3rem] text-center text-inverse-on-surface gsap-reveal">
            <h2 class="font-headline text-4xl font-bold mb-8">Ready to scale your support and commerce?</h2>
            <p class="text-slate-400 text-xl mb-12">
                Let's discuss how I can help you build more resilient integrations and better customer workflows.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-6">
                <a href="mailto:contact@sakaru.com.np" class="bg-primary text-on-primary font-headline font-bold py-4 px-10 rounded-2xl hover:scale-105 transition-all">
                    Inquire for Consulting
                </a>
                <a href="/portfolio" class="border border-white/20 hover:bg-white/10 font-headline font-bold py-4 px-10 rounded-2xl transition-all">
                    View Portfolio
                </a>
            </div>
        </section>
    </main>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(ScrollTrigger);
            gsap.utils.toArray(".gsap-reveal").forEach((section) => {
                gsap.from(section, {
                    opacity: 0,
                    y: 40,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: section,
                        start: "top 85%",
                    }
                });
            });
        });
    </script>
</BaseLayout>
