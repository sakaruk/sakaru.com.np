---
import BaseLayout from '../../layouts/BaseLayout.astro';

const talks = [
    {
        title: "Coz Speed Matters",
        description: "The talk focuses on the critical role of website performance in the modern digital landscape.",
        type: "Talk / Optimization",
        thumbnail: "https://videos.files.wordpress.com/RDX0xriJ/video-59ec50136c_scruberthumbnail_0.jpg",
        video_url: "https://wordpress.tv/2015/03/10/sakar-upadhyaya-khatiwada-because-website-speed-matters/",
        slides_url: "https://www.slideshare.net/slideshow/coz-speed-matters-wordpress-optimization/41890594"
    },
    {
        title: "Accessible WordPress(ing)",
        description: "The talk focuses on the importance of web accessibility and how to make WordPress websites more accessible to all users.",
        type: "Talk / Accessibility",
        thumbnail: "https://videos.files.wordpress.com/ZxhTd5hN/video-ad805490ad_scruberthumbnail_0.jpg",
        video_url: "https://wordpress.tv/2015/12/30/sakar-upadhyaya-khatiwada-accessible-wordpressing/",
        slides_url: "https://www.slideshare.net/slideshow/accessible-wordpressing/55362625"
    },
    {
        title: "Soft skill toppings for spicing up your WordPress professionalism",
        description: "This session aims to highlight the importance of soft skills that can help us shine as a WordPress professional in the professional realm, emphasizing professionalism over just technical proficiency. Whether you're a developer, designer, content creator, or any other kind of professional in the WordPress space, enhancing your soft skills can significantly boost your career prospects and effectiveness.",
        type: "Talk / Soft Skills",
        thumbnail: "https://videos.files.wordpress.com/81YlrOoV/video-888f1944a4_scruberthumbnail_1.jpg",
        video_url: "https://wordpress.tv/2018/05/05/sakar-upadhyaya-khatiwada-soft-skill-toppings-for-spicing-up-your-wordpress-professionalism/",
    },
    {
        title: "Thinking the React Way for WordPress Developers",
        description: "Talk focuses on developing the mental model to understand react to be used in building Blocks and FSE components  as a PHP Developer",
        type: "Talk / React & WordPress",
        thumbnail: "https://videos.files.wordpress.com/T8GpaCak/video-28354b5f96_mp4.scrubthumb.jpg",
        video_url: "https://wordpress.tv/2022/10/01/thinking-the-react-way-for-wordpress-developers/",
    },
    {
        title: "Dissecting WordPress Playground",
        description: "Showcases features and usecases of WordPress Playground.",
        type: "Lightning Talk",
        thumbnail: "https://videos.files.wordpress.com/FVjSjW6V/video-4d756dc6b9_mp4.scrubthumb.jpg",
        video_url: "https://wordpress.tv/2025/04/30/dissecting-wordpress-playground/",
    }
];

const communityContributions = [
    {
        title: "Web Weekend Kathmandu",
        description: "Part of the organizing team for Tech Kura Kani, AI Conf 2026, and BarCamp Kathmandu 2024 & 2025 editions, actively fostering the local tech community.",
        icon: "groups",
        colorClass: "tertiary",
        link: {
            url: "https://community.wwktm.com/",
            label: "Join The Community"
        }
    },
    {
        title: "WordCamp Speaker",
        description: "Bringing Web Concepts and joining it with Wordpress Ecosystem. The  talks that helps people to understand the WordPress ecosystem better.",
        icon: "record_voice_over",
        colorClass: "tertiary",
        link: {
            url: "https://wordpress.tv/speakers/sakar-upadhyaya-khatiwada/",
            label: "Watch Videos"
        }
    },
    {
        title: "Community Supporter",
        description: "Part of developer communities in Kathmandu and Online. Attending events and learning from others and sharing my knowledge and experience. Previous organizer of PHP Developers Meetup and Shopify Meetup in Nepal.",
        icon: "hub",
        colorClass: "tertiary",
    },
    {
        title: "Open Source Contributor",
        description: "Actively developing and maintaining open-source repositories and tools under the SaaSPal.",
        icon: "code",
        colorClass: "tertiary",
        link: {
            url: "https://github.com/saaspal",
            label: "View GitHub Profile"
        }
    }
];
---

<BaseLayout title="Community & Talks | Sakar Upadhyaya Khatiwada">
    <main class="pt-24 pb-20 max-w-7xl mx-auto px-8">
        <!-- Hero Section -->
        <header class="py-20 lg:py-32 flex flex-col items-start gsap-reveal">
            <div class="inline-block px-4 py-1.5 rounded-full bg-primary-fixed text-on-primary-fixed font-label text-xs uppercase tracking-widest mb-6">
                Community & Speaking
            </div>
            <h1 class="text-6xl md:text-8xl font-headline font-extrabold tracking-tighter text-on-surface mb-8">
                Community & Talks
            </h1>
            <p class="text-xl md:text-2xl text-on-surface-variant max-w-3xl font-body leading-relaxed">
                Fostering the local tech community and sharing engineering insights on distributed systems, high-scale integrations, and the future of SaaS architecture at global stages.
            </p>
        </header>

        <!-- Community Contributions Section -->
        <section class="mb-32 gsap-reveal">
            <h2 class="text-4xl md:text-5xl font-headline font-black text-on-surface mb-12">Community Involvement</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {communityContributions.map((item) => (
                    <div class={`bg-surface-container-low p-10 rounded-3xl border border-transparent hover:border-${item.colorClass}/20 transition-all duration-300 shadow-xl shadow-${item.colorClass}/5 hover:-translate-y-1 flex flex-col`}>
                        <div class={`w-16 h-16 bg-${item.colorClass}/10 rounded-2xl flex items-center justify-center mb-6`}>
                            <span class={`material-symbols-outlined text-3xl text-${item.colorClass}`} data-icon={item.icon}>{item.icon}</span>
                        </div>
                        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">{item.title}</h3>
                        <p class="text-on-surface-variant leading-relaxed mb-6 flex-1">
                            {item.description}
                        </p>
                        {item.link && (
                            <a href={item.link.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-primary font-label font-bold text-sm uppercase tracking-widest hover:text-primary-variant transition-colors group mt-auto">
                                {item.link.label}
                                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" data-icon="open_in_new">open_in_new</span>
                            </a>
                        )}
                    </div>
                ))}
            </div>
        </section>

        <!-- Talks List Section -->
        <section class="mb-32">
            <h2 class="text-4xl md:text-5xl font-headline font-black text-on-surface mb-12 gsap-reveal">Talks</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {talks.map((talk: any) => (
                    <article class="group gsap-reveal">
                        <!-- Image/Thumbnail area -->
                        <div class="aspect-video bg-surface-container-high rounded-3xl mb-8 overflow-hidden relative border border-transparent group-hover:border-primary/30 transition-all duration-500 block">
                            <a href={talk.v} class="absolute inset-0 z-10"></a>
                            <img 
                                src={talk.thumbnail || "https://lh3.googleusercontent.com/aida-public/AB6AXuCr9HE521CGJX6vYPXdqO_8TbRlNO_T6N_G8Rb3AyGZZ1NgCsVo3iRAMdibCICthOQ3oP0VsjLAKw2UZ99fZFNo04mcC-IZW-zKaxo2ovefhFLxvOcJrTxW-Cl6GCWOxnB3Bbt8ntZCW9pEBEhl-Z6f8lLcm31W-VaZfAOW_NpaQwIVAIzjVVteqmfr-tTAoixHwAWdyd0nIN1RV9aJJi-7Wjftt5VZlnNS2h01UhLPmch1c-C-17f8CJLq8GPkmqmliIcDAkDiJ5HM"} 
                                alt={talk.title} 
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 relative z-0" 
                            />
                            <div class="absolute inset-0 bg-primary/10 mix-blend-overlay z-0"></div>
                        </div>
                        
                        <div class="px-4">
                            <div class="flex items-center gap-3 mb-3">
                                <span class="font-label text-xs font-bold text-primary block uppercase tracking-widest">{talk.type || "Talk"}</span>
                                <span class="h-px w-4 bg-outline-variant"></span>
                            </div>
                            <h2 class="font-headline text-3xl font-bold mb-4 group-hover:text-primary transition-colors">
                                <a href={talk.customUrl} class="relative z-10">{talk.title}</a>
                            </h2>
                            <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
                                {talk.description}
                            </p>
                            <div class="flex flex-wrap gap-4 relative z-10">
                                {talk.video_url && (
                                    <a href={talk.video_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-primary font-label font-bold text-sm hover:underline">
                                        <span class="material-symbols-outlined text-lg" data-icon="play_circle">play_circle</span>
                                        Watch Video
                                    </a>
                                )}
                                {talk.slides_url && (
                                    <a href={talk.slides_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-on-surface-variant font-label font-bold text-sm hover:text-on-surface hover:underline transition-colors">
                                        <span class="material-symbols-outlined text-lg" data-icon="auto_stories">auto_stories</span>
                                        Slides
                                    </a>
                                )}
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <!-- CTA Section -->
        <section class="mt-32 gsap-reveal">
            <div class="bg-gradient-to-br from-primary to-tertiary rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden shadow-2xl shadow-primary/20">
                <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-black/10 rounded-full blur-3xl"></div>
                
                <div class="relative z-10">
                    <h2 class="text-4xl md:text-6xl font-headline font-black text-on-primary mb-8 tracking-tighter">
                        Invite Me to Speak
                    </h2>
                    <p class="text-xl md:text-2xl text-on-primary/80 max-w-2xl mx-auto mb-12 font-body leading-relaxed">
                        Looking for a speaker to discuss SaaS engineering, platform integrations, or technical community building?
                    </p>
                    <a href="mailto:sakar@saaspal.us" class="inline-flex items-center gap-4 bg-surface-container-lowest text-primary px-10 py-5 rounded-full font-headline font-black text-xl hover:scale-105 active:scale-95 transition-transform">
                        Send an Invite
                        <span class="material-symbols-outlined font-bold" data-icon="mail">mail</span>
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
