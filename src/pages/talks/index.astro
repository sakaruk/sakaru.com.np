---
import BaseLayout from '../../layouts/BaseLayout.astro';

const talks = import.meta.glob('../../../data/talks/*.md', { eager: true });
const sortedTalks = Object.values(talks).map((p: any) => ({
    ...p,
    customUrl: '/talks/' + p.file.split('/').pop().replace('.md', '')
})).sort((a: any, b: any) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<BaseLayout title="Talks | Sakar Upadhyaya Khatiwada">
    <main class="pt-24 pb-20 max-w-7xl mx-auto px-8">
        <!-- Hero Section -->
        <header class="py-20 lg:py-32 flex flex-col items-start gsap-reveal">
            <div class="inline-block px-4 py-1.5 rounded-full bg-primary-fixed text-on-primary-fixed font-label text-xs uppercase tracking-widest mb-6">
                Keynotes & Speaking
            </div>
            <h1 class="text-6xl md:text-8xl font-headline font-extrabold tracking-tighter text-on-surface mb-8">
                Talks & Keynotes
            </h1>
            <p class="text-xl md:text-2xl text-on-surface-variant max-w-3xl font-body leading-relaxed">
                Sharing engineering insights on distributed systems, high-scale integrations, and the future of SaaS architecture at global stages.
            </p>
        </header>

        <!-- Talks List Section -->
        <section class="flex flex-col gap-12">
            {sortedTalks.map((talk: any) => (
                <article class="gsap-reveal group flex flex-col md:flex-row gap-10 items-start p-8 rounded-3xl bg-surface-container-low hover:bg-surface-container-lowest transition-all duration-300 shadow-sm shadow-primary/5 relative">
                    <a href={talk.customUrl} class="absolute inset-0 z-0"></a>
                    <div class="w-full md:w-1/3 aspect-[16/10] overflow-hidden rounded-2xl relative z-10 pointer-events-none">
                        <img 
                            src={talk.frontmatter.thumbnail || "https://lh3.googleusercontent.com/aida-public/AB6AXuCr9HE521CGJX6vYPXdqO_8TbRlNO_T6N_G8Rb3AyGZZ1NgCsVo3iRAMdibCICthOQ3oP0VsjLAKw2UZ99fZFNo04mcC-IZW-zKaxo2ovefhFLxvOcJrTxW-Cl6GCWOxnB3Bbt8ntZCW9pEBEhl-Z6f8lLcm31W-VaZfAOW_NpaQwIVAIzjVVteqmfr-tTAoixHwAWdyd0nIN1RV9aJJi-7Wjftt5VZlnNS2h01UhLPmch1c-C-17f8CJLq8GPkmqmliIcDAkDiJ5HM"} 
                            alt={talk.frontmatter.title} 
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                        />
                        <div class="absolute inset-0 bg-primary/10 mix-blend-overlay"></div>
                    </div>
                    
                    <div class="flex-1 space-y-4 relative z-10">
                        <div class="flex items-center gap-3">
                            <span class="font-label text-sm text-primary font-bold uppercase tracking-widest pointer-events-none">{talk.frontmatter.type || "Talk"}</span>
                            <span class="h-px w-8 bg-outline-variant pointer-events-none"></span>
                            <span class="font-label text-sm text-on-surface-variant pointer-events-none">{talk.frontmatter.date}</span>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-headline font-bold text-on-surface leading-tight group-hover:text-primary transition-colors pointer-events-none">
                            {talk.frontmatter.title}
                        </h2>
                        <p class="text-lg text-on-surface-variant leading-relaxed font-body pointer-events-none mb-4">
                            {talk.frontmatter.description}
                        </p>
                        <div class="pt-4 flex flex-wrap gap-4">
                            {talk.frontmatter.video_url && (
                                <a href={talk.frontmatter.video_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary rounded-full font-headline font-bold text-sm hover:scale-105 transition-transform relative z-20">
                                    <span class="material-symbols-outlined text-lg" data-icon="play_circle">play_circle</span>
                                    Watch Video
                                </a>
                            )}
                            {talk.frontmatter.slides_url && (
                                <a href={talk.frontmatter.slides_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary text-primary rounded-full font-headline font-bold text-sm hover:bg-primary/5 transition-colors relative z-20">
                                    <span class="material-symbols-outlined text-lg" data-icon="auto_stories">auto_stories</span>
                                    Slides
                                </a>
                            )}
                        </div>
                    </div>
                </article>
            ))}
        </section>

        <!-- CTA Section -->
        <section class="mt-32 gsap-reveal">
            <div class="bg-gradient-to-br from-primary to-tertiary rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden shadow-2xl shadow-primary/20">
                <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-black/10 rounded-full blur-3xl"></div>
                
                <div class="relative z-10">
                    <h2 class="text-4xl md:text-6xl font-headline font-extrabold text-on-primary mb-8 tracking-tighter">
                        Invite Me to Speak
                    </h2>
                    <p class="text-xl md:text-2xl text-on-primary/80 max-w-2xl mx-auto mb-12 font-body">
                        Looking for a speaker to discuss SaaS engineering, platform integrations, or technical leadership?
                    </p>
                    <a href="mailto:sakar@saaspal.us" class="inline-flex items-center gap-4 bg-surface-container-lowest text-primary px-10 py-5 rounded-full font-headline font-extrabold text-xl hover:scale-105 active:scale-95 transition-transform">
                        Send an Invite
                        <span class="material-symbols-outlined font-bold" data-icon="mail">mail</span>
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
