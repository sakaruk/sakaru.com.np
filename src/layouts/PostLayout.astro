---
import BaseLayout from './BaseLayout.astro';
const { content } = Astro.props;
---
<BaseLayout 
  title={`${content.title} | Sakar Upadhyaya Khatiwada`} 
  description={content.description} 
  image={content.thumbnail}
>

	<main class="pt-32 pb-20 min-h-[85vh]">
		<article class="max-w-4xl mx-auto px-8 prose prose-lg prose-blue dark:prose-invert">
            <div class="mb-12 not-prose">
                <time class="font-label text-sm text-gray-500 uppercase tracking-widest">{content.date}</time>
                <h1 class="text-5xl font-headline font-extrabold tracking-tighter text-on-surface mt-2 mb-6 leading-tight">
                    {content.title}
                </h1>
                <div class="flex items-center gap-6 mb-8 text-on-surface-variant font-body text-sm">
                    {content.author && (
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-base" data-icon="person">person</span>
                            <span>{content.author}</span>
                        </div>
                    )}
                    {content.readingTime && (
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-base" data-icon="schedule">schedule</span>
                            <span>{content.readingTime}</span>
                        </div>
                    )}
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-base" data-icon="label">label</span>
                        <span class="text-xs font-label font-bold text-tertiary bg-tertiary-fixed px-3 py-1 rounded-full">{content.tag}</span>
                    </div>
                </div>
            </div>
            
            {content.thumbnail && (
                <div class="w-full aspect-[21/9] overflow-hidden rounded-2xl mb-12 not-prose">
                    <img src={content.thumbnail} alt={content.title} class="w-full h-full object-cover" />
                </div>
            )}
            
			<slot />
		</article>
	</main>
</BaseLayout>

