---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the leading slash

const isActive = (path: string) => {
    if (path === '' && currentPath === '') return true;
    if (path !== '' && currentPath.startsWith(path)) return true;
    return false;
};
---

<header class="fixed top-0 w-full z-50 bg-slate-50/70 dark:bg-slate-950/70 backdrop-blur-xl z-[9999]">
  <div class="max-w-7xl mx-auto px-8 py-4 flex flex-col md:flex-row justify-between md:items-center">
    <div class="flex justify-between items-center w-full md:w-auto">
        <a href="/" class="text-xl font-bold tracking-tighter text-slate-900 dark:text-slate-100 font-headline animate-fade-in">
          Sakar Upadhyaya Khatiwada
        </a>
        <button id="mobile-menu-trigger" class="md:hidden text-slate-900 dark:text-slate-100 p-2 focus:outline-none">
            <span class="material-symbols-outlined" data-icon="menu">menu</span>
        </button>
    </div>
    
    <nav id="nav-links" class="hidden md:flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-8 font-['Plus_Jakarta_Sans'] font-semibold tracking-tight mt-6 md:mt-0 pb-4 md:pb-0">
      <a 
        href="/"
        class={`transition-all duration-200 ${isActive('') ? 'text-blue-600 dark:text-blue-400 font-bold border-b-2 border-blue-600 dark:border-blue-400 pb-1' : 'text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:opacity-80'}`}
      >
        Home
      </a>
      <a 
        href="/about"
        class={`transition-all duration-200 ${isActive('about') ? 'text-blue-600 dark:text-blue-400 font-bold border-b-2 border-blue-600 dark:border-blue-400 pb-1' : 'text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:opacity-80'}`}
      >
        About
      </a>
      <a 
        href="/portfolio"
        class={`transition-all duration-200 ${isActive('portfolio') ? 'text-blue-600 dark:text-blue-400 font-bold border-b-2 border-blue-600 dark:border-blue-400 pb-1' : 'text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:opacity-80'}`}
      >
        Portfolio
      </a>
      <a 
        href="/blog"
        class={`transition-all duration-200 ${isActive('blog') ? 'text-blue-600 dark:text-blue-400 font-bold border-b-2 border-blue-600 dark:border-blue-400 pb-1' : 'text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:opacity-80'}`}
      >
        Blog
      </a>
      <a 
        href="/community"
        class={`transition-all duration-200 ${isActive('community') ? 'text-blue-600 dark:text-blue-400 font-bold border-b-2 border-blue-600 dark:border-blue-400 pb-1' : 'text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:opacity-80'}`}
      >
        Community
      </a>
    </nav>
  </div>
</header>
<script is:inline>
    const menuBtn = document.getElementById('mobile-menu-trigger');
    const navLinks = document.getElementById('nav-links');
    menuBtn?.addEventListener('click', () => {
        navLinks?.classList.toggle('hidden');
        navLinks?.classList.toggle('flex');
    });
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>
