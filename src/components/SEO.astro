---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: URL | string;
}

const {
  title = "Zendesk Developer & Shopify Engineer | Sakar Upadhyaya Khatiwada",
  description = "Freelance Zendesk developer and Shopify engineer based in Nepal. 10+ years specializing in complex SaaS integrations, custom Zendesk apps, and Shopify Plus engineering.",
  image = "https://images.unsplash.com/photo-1571401835393-8c5f35328320?w=1200&q=75",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
---

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- OpenGraph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={image} />

<!-- JSON-LD Person Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Sakar Upadhyaya Khatiwada",
  "url": "https://sakaru.com.np",
  "jobTitle": "Senior Software Engineer",
  "knowsAbout": ["Zendesk Development", "Shopify Engineering", "SaaS Integration"],
  "sameAs": [
    "https://linkedin.com/in/sakaruk",
    "https://github.com/sakaruk",
    "https://twitter.com/sakaruk"
  ]
}
</script>
