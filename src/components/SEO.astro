---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const currentYear = new Date().getFullYear();
const experienceYears = currentYear - 2013;

const {
  title = "Zendesk Developer & Shopify Engineer | Sakar Upadhyaya Khatiwada",
  description = `Zendesk Developer & Shopify Engineer based in Nepal. ${experienceYears}+ years experience in building web applications and solutions.`,
  image = "/images/site_image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const resolvedImage = image.startsWith('http') ? image : new URL(image, Astro.site || Astro.url.origin);

// JSON-LD Person Schema based on April 2026 Audit
const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Sakar Upadhyaya Khatiwada",
  "alternateName": "Sakar UK",
  "url": "https://sakaru.com.np",
  "jobTitle": "Zendesk Solution Architect & Shopify Engineer",
  "description": description,
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "St. Xavier's College, Kathmandu"
  },
  "knowsAbout": ["Zendesk ZAF", "Shopify App Development", "Customer Experience (CX)", "Management Systems", "React", "TypeScript", "Laravel", "APIs and Automations"],
  "worksFor": {
    "@type": "Organization",
    "name": "Freelance Consultant"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Madhyapur Thimi",
    "addressRegion": "Bhaktapur",
    "addressCountry": "Nepal"
  },
  "sameAs": [
    "https://linkedin.com/in/sakaruk",
    "https://github.com/sakaruk",
    "https://twitter.com/sakaruk"
  ]
};
---

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- OpenGraph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedImage} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={resolvedImage} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
